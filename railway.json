{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "dockerfilePath": "Dockerfile.railway"
  },
  "deploy": {
    "healthcheckPath": "/health",
    "healthcheckTimeout": 10,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3,
    "envVars": {
      "API_KEY": {
        "description": "API key for your Anthropic-compatible provider endpoint",
        "required": true
      },
      "ZEROCLAW_PROVIDER": {
        "description": "Anthropic-compatible custom provider endpoint (format: anthropic-custom:https://your-proxy-host)",
        "required": false,
        "default": "https://api.tu-zi.com"
      },
      "ZEROCLAW_MODEL": {
        "description": "Claude model name for the selected provider endpoint",
        "required": false,
        "default": "claude-sonnet-4-5-20250929"
      },
      "ZEROCLAW_PROXY_ENABLED": {
        "description": "Enable ZeroClaw managed proxy forwarding",
        "required": false,
        "default": "true"
      },
      "ZEROCLAW_HTTPS_PROXY": {
        "description": "HTTPS proxy URL (e.g. http://proxy.example.com:8080)",
        "required": false
      },
      "ZEROCLAW_HTTP_PROXY": {
        "description": "HTTP proxy URL (e.g. http://proxy.example.com:8080)",
        "required": false
      },
      "ZEROCLAW_TEMPERATURE": {
        "description": "Model temperature (0.0–2.0)",
        "required": false,
        "default": "0.7"
      },
      "ZEROCLAW_ALLOW_PUBLIC_BIND": {
        "description": "Allow binding to public interfaces (must be true for Railway)",
        "required": false,
        "default": "true"
      },
      "ZEROCLAW_GATEWAY_HOST": {
        "description": "Gateway bind address (0.0.0.0 for Railway networking)",
        "required": false,
        "default": "0.0.0.0"
      }
    }
  }
}